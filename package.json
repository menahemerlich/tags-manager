{
  "name": "tags-manager",
  "version": "1.0.4",
  "description": "Tag-based file and folder manager",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/download-onnx-face-models.mjs && node scripts/download-face-models.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/copy-renderer-public.mjs && electron-builder",
    "build:vite": "electron-vite build && node scripts/copy-renderer-public.mjs",
    "preview": "electron-vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "electron-updater": "^6.3.9",
    "face-api.js": "^0.22.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "jimp": "^1.6.0",
    "konva": "^10.2.5",
    "onnxruntime-node": "^1.24.3",
    "react-konva": "^18.2.14",
    "react-virtuoso": "^4.18.3",
    "semver": "^7.6.3",
    "sql.js": "^1.12.0"
  },
  "overrides": {
    "wcwidth": "1.0.1",
    "promise-inflight": "1.0.1",
    "path-is-absolute": "1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/semver": "^7.5.8",
    "@vitejs/plugin-react": "^4.3.4",
    "electron-rebuild": "^3.2.9",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "node-addon-api": "^8.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.6"
  },
  "build": {
    "appId": "com.tagsmanager.app",
    "productName": "Tags Manager",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "build/icon.png",
      "resources/models/face/**/*",
      "resources/ffmpeg/**/*"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "asarUnpack": [
      "**/node_modules/sql.js/dist/**",
      "**/node_modules/onnxruntime-node/bin/**",
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**",
      "resources/models/face/**",
      "resources/ffmpeg/**"
    ],
    "win": {
      "artifactName": "${name}-setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "menahemerlich",
        "repo": "tags-manager"
      }
    ]
  }
}
